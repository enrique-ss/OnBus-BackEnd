# =====================================================
# OnBus - Variáveis de Ambiente
# =====================================================
# COMO USAR
#   Local (desenvolvimento): copie este arquivo para .env e rode sem alterar
#     nada. O banco usado é SQLite (arquivo backend/onbus.db), criado
#     automaticamente.
#
#       cp .env.example .env
#
#   Online (produção): mude NODE_ENV para "production" e preencha DATABASE_URL
#     (e, se for usar o Supabase no cliente, as variáveis SUPABASE_*).
# =====================================================


# =====================================================
# AMBIENTE
# =====================================================
# development = banco SQLite local | production = PostgreSQL/Supabase
NODE_ENV=development

# Porta do servidor HTTP
PORT=3000


# =====================================================
# AUTENTICAÇÃO / SEGURANÇA
# =====================================================
# Chave secreta para assinar tokens JWT.
# Em produção, troque por uma string longa e aleatória.
JWT_SECRET=chave-secreta-super-segura-123

# Chave secreta para validar webhooks de pagamento (HMAC SHA-256).
WEBHOOK_SECRET=webhook_secret_key


# =====================================================
# PRODUÇÃO / ONLINE (deixe vazio para rodar local com SQLite)
# =====================================================
# String de conexão PostgreSQL do Supabase.
# Só é usada quando NODE_ENV=production.
DATABASE_URL=

# Credenciais do projeto Supabase (preencha apenas se for usar online).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
